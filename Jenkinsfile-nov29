pipeline{
  agent any 
  triggers {
    pollSCM('* * * * *')  // Keep your 1-minute polling
  }
  tools {
    maven "maven3.9.9"     // Note: Your log shows maven3.9.9 is actually being used
  }
  
  stages {
    stage('Clone & Build'){
      steps{
        sh "echo 'Cloning repository and building application' "
        git branch: 'terry', url: 'https://github.com/Lion-Technology-Solutions/liontech-online-library-web-app.git'
        
        // This ONE command does everything: clean, compile, test, package
        // No need for separate install/test/validate calls
        sh "mvn clean package"
      }
    }
    
    stage('Code Quality - SonarQube'){
      steps{
        sh "echo 'Performing Code Quality Analysis with SonarQube' "
        // Run Sonar analysis on the already-built code
        sh "mvn sonar:sonar"
      }
    }
    
    stage('Deploy to Nexus'){
      steps{
        sh "echo 'Uploading artifacts to Nexus repository' "
        // 'deploy' includes 'install' automatically
        sh "mvn deploy"
      }
    }
    
    stage('Deploy to Production Tomcat'){
      steps{
        sh "echo 'Deploying WAR to production Tomcat server' "
        deploy adapters: [
          tomcat9(
            alternativeDeploymentContext: '', 
            credentialsId: 'e293ab7a-6c16-4fcc-9c2a-19c6c66d9e6e', 
            path: '', 
            url: 'http://3.97.15.34:8009/'
          )
        ], 
        contextPath: 'terry', 
        war: 'target/*.war'
      }
    }
  }
  
  // Your post-build email notifications remain the same
  post{
    always{
      emailext body: '''Hey guys
Please check build status.

Thanks
LionTech 
+1 437 215 2483''', recipientProviders: [buildUser(), developers()], subject: 'Build Notification', to: 'paypal-team@gmail.com'
    }
    success{
      emailext body: '''Hey guys
Good job build and deployment is successful.

Thanks
LionTech 
+1 437 215 2483''', recipientProviders: [buildUser(), developers()], subject: 'Build SUCCESS', to: 'paypal-team@gmail.com'
    } 
    failure{
      emailext body: '''Hey guys
Build failed. Please resolve issues.

Thanks
LionTech 
+1 437 215 2483''', recipientProviders: [buildUser(), developers()], subject: 'Build FAILED', to: 'paypal-team@gmail.com'
    }
  }
}