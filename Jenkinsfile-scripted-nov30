node{
  // Configure SCM polling - runs every minute
  properties([
    pipelineTriggers([
      pollSCM('* * * * *')  // Polls SCM every minute (adjust as needed)
    ]),
    buildDiscarder(logRotator(numToKeepStr: '10'))
  ])
  
  def mavenHome = tool name: 'maven3.9.9'
  
  stage('1cloneCode'){
    git branch: 'terry', url: 'https://github.com/Lion-Technology-Solutions/liontech-online-library-web-app.git'
  }
  
  stage('2Test&Build'){
    // Note: You don't need to run all these Maven commands separately
    // 'mvn clean install' already runs validate, compile, test, package, verify, and install
    sh "${mavenHome}/bin/mvn clean install"
  }
  
  stage('3codeQuality'){
    sh "${mavenHome}/bin/mvn sonar:sonar"
  }
  
  stage('4uploadArtifacts'){
    // If you want to deploy to artifact repository
    // sh "${mavenHome}/bin/mvn deploy"
    // Note: You'll need to configure settings.xml with credentials
  } 
  
  stage('deploy2dev'){
    sh "echo 'Deploying to dev environment'"
    deploy adapters: [tomcat9(alternativeDeploymentContext: '', 
                    credentialsId: 'e293ab7a-6c16-4fcc-9c2a-19c6c66d9e6e', 
                    path: '', 
                    url: 'http://your-dev-tomcat-server:8080/')],  // Fix this URL
                    contextPath: 'dev', 
                    war: 'target/*.war'
  }

  stage('deploy2Test'){
    sh "echo 'Deploying to Test environment'"
    deploy adapters: [tomcat9(alternativeDeploymentContext: '', 
                    credentialsId: 'e293ab7a-6c16-4fcc-9c2a-19c6c66d9e6e', 
                    path: '', 
                    url: 'http://3.97.15.34:8009/')], 
                    contextPath: 'Test', 
                    war: 'target/*.war'
  }

  stage('5deploy2UAT'){
    sh "echo 'Deploying to UAT environment'"
    deploy adapters: [tomcat9(alternativeDeploymentContext: '', 
                    credentialsId: 'e293ab7a-6c16-4fcc-9c2a-19c6c66d9e6e', 
                    path: '', 
                    url: 'http://3.97.15.34:8009/')], 
                    contextPath: 'UAT', 
                    war: 'target/*.war'
  }
  
  stage('6approvalGate'){
    sh "echo 'Application ready for production deployment. Waiting for approval...'"
    timeout(time: 5, unit: 'DAYS') {
      input message: 'Application ready for PRODUCTION deployment. Please review and approve.',
            id: 'prod-approval',
            submitter: 'admin,dev-team'
    }
  }
  
  stage('7deploy2Prod'){
    sh "echo 'Deploying to PRODUCTION environment...'"
    sh "sleep 30"  // Optional: Give time for any last-minute checks
    
    deploy adapters: [tomcat9(alternativeDeploymentContext: '', 
                    credentialsId: 'e293ab7a-6c16-4fcc-9c2a-19c6c66d9e6e', 
                    path: '', 
                    url: 'http://3.97.15.34:8009/')], 
                    contextPath: 'PROD', 
                    war: 'target/*.war'
  }

  stage('congratulations') {
    echo 'Congratulations Lion Tech Engineers! Deployment successful!'
  }
            
  stage('8emailNotification'){
    emailext body: '''Hi All,

The build and deployment process has completed successfully.

Application Status: ${BUILD_STATUS}
Build Number: ${BUILD_NUMBER}
Build URL: ${BUILD_URL}

Thanks,
Lion Technologies''', 
           recipientProviders: [buildUser(), developers(), upstreamDevelopers()], 
           subject: "Build Status: ${currentBuild.currentResult} - ${JOB_NAME} #${BUILD_NUMBER}",
           to: 'info@liontechacademy.com'
  }
  
  // Post-build actions
  post {
    success {
      echo 'Pipeline executed successfully!'
      // Optional: Add success notifications here
    }
    failure {
      echo 'Pipeline failed!'
      emailext body: '''Hi Team,

The build has FAILED!

Build Number: ${BUILD_NUMBER}
Job: ${JOB_NAME}
Failed Stage: ${STAGE_NAME}
Build URL: ${BUILD_URL}

Please investigate immediately.

Thanks,
Lion Technologies''',
             subject: "URGENT: Build FAILED - ${JOB_NAME} #${BUILD_NUMBER}",
             to: 'info@liontechacademy.com,dev-team@liontechacademy.com'
    }
    unstable {
      echo 'Pipeline is unstable!'
    }
  }
}